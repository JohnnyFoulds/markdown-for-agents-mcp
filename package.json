{
  "name": "markdown-for-agents-mcp",
  "version": "1.0.0",
  "type": "module",
  "description": "MCP server for AI agents - fetch URLs and convert to clean markdown with JavaScript rendering",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "markdown-mcp": "dist/index.js",
    "markdown-cli": "cli.js"
  },
  "files": [
    "dist",
    "cli.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "postinstall": "node scripts/install-playwright.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "agent",
    "markdown",
    "playwright",
    "html-to-markdown"
  ],
  "mcpName": "io.github.JohnnyFoulds/markdown-for-agents-mcp",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:JohnnyFoulds/markdown-for-agents-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "markdown-for-agents": "^1.0.0",
    "playwright": "^1.40.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
