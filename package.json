{
  "name": "markdown-for-agents-mcp",
  "version": "1.0.1",
  "type": "module",
  "description": "MCP server for AI agents — fetch any URL with full JavaScript rendering (Playwright/Chromium) and convert to clean, token-efficient markdown. Works on React, Vue, Angular, and any JS-heavy page.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "markdown-mcp": "dist/index.js",
    "markdown-cli": "cli.js"
  },
  "files": [
    "dist",
    "cli.js",
    "scripts/install-playwright.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "postinstall": "node scripts/install-playwright.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "agent",
    "markdown",
    "playwright",
    "html-to-markdown",
    "web-scraping",
    "fetch",
    "spa",
    "chromium",
    "llm",
    "mcp-server",
    "javascript-rendering"
  ],
  "mcpName": "io.github.JohnnyFoulds/markdown-for-agents-mcp",
  "author": "JohnnyFoulds",
  "license": "MIT",
  "homepage": "https://github.com/JohnnyFoulds/markdown-for-agents-mcp#readme",
  "bugs": {
    "url": "https://github.com/JohnnyFoulds/markdown-for-agents-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JohnnyFoulds/markdown-for-agents-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "markdown-for-agents": "^1.0.0",
    "playwright": "^1.40.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
