{
  "name": "markdown-for-agents-mcp",
  "version": "0.1.0",
  "description": "MCP server for AI agents - fetch URLs and convert to clean markdown with JavaScript rendering",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "markdown-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "postinstall": "node scripts/install-playwright.js",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "agent",
    "markdown",
    "playwright",
    "html-to-markdown"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:JohnnyFoulds/markdown-for-agents-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "markdown-for-agents": "^1.0.0",
    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
