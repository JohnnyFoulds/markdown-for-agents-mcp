# Fetch Configuration
FETCH_TIMEOUT_MS=30000              # Timeout for fetch requests in milliseconds
MAX_CONCURRENT_FETCHES=5            # Maximum concurrent fetch operations
STABILIZATION_DELAY_MS=2000         # Wait time for JS rendering before content extraction
MAX_REDIRECTS=10                    # Maximum redirect hops before error
MAX_CONTENT_LENGTH=100000           # Maximum content size in characters

# Logging Configuration
LOG_LEVEL=INFO                      # DEBUG, INFO, WARN, ERROR
LOG_FORMAT=text                     # text or json

# Cache Configuration
CACHE_MAX_BYTES=52428800            # Maximum cache size in bytes (50MB)
CACHE_TTL_MS=900000                 # Cache time-to-live in milliseconds (15 minutes)

# Security Configuration
USE_ALLOWLIST_MODE=false            # If true, only allow explicitly whitelisted domains
BLOCKLIST_DOMAINS=                  # Comma-separated list of blocked domains
BLOCKLIST_URL_PATTERNS=             # Comma-separated list of blocked URL patterns

# Web Search Configuration
WEB_SEARCH_MAX_RESULTS=10           # Maximum search results to return
WEB_SEARCH_DEFAULT_TIMEOUT_MS=30000 # Default timeout for search requests (ms)
